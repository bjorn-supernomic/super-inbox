{
  "name": "super-inbox",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run db:migrate && bunx flue dev --port 4820",
    "db:migrate": "mkdir -p data && atlas migrate apply --env local --url sqlite://data/inbox.db",
    "db:diff": "atlas migrate diff --env local",
    "agent:demo": "curl -s -X POST 'http://localhost:4820/workflows/file-signal?wait=result' -H 'content-type: application/json' -d @signals/example.json",
    "build:toolbar": "bun build agentation-src.jsx --outfile agentation-toolbar.js --minify --define process.env.NODE_ENV='\"production\"'",
    "build:glimm": "bun build glimm-src.jsx --outfile glimm-sweep.js --minify --define process.env.NODE_ENV='\"production\"'"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.9",
    "agentation": "3.0.2",
    "drizzle-kit": "^0.31.10",
    "glimm": "0.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "@flue/runtime": "^1.0.0-beta.9",
    "@hono/node-server": "^2.0.10",
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "valibot": "^1.4.2"
  }
}
