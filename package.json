  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.9",
    "agentation": "3.0.2",
    "glimm": "0.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "@flue/runtime": "^1.0.0-beta.9",
    "valibot": "^1.4.2"
  }
}
