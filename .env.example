# Copy to .env (gitignored) and fill in. Only ANTHROPIC_API_KEY is required
# to run the LLM agent — everything else has a working default.

# — Agents (Flue workflow: src/workflows/investigate-signal.ts) —

# Required. Powers the investigation model (default anthropic/claude-sonnet-4-6).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Optional. Any Pi model specifier to use a different model/provider,
# e.g. "anthropic/claude-haiku-4-5" for cheap test runs, or a
# "cloudflare/..." model (needs no Anthropic key). See https://pi.dev/models
# FLUE_MODEL="anthropic/claude-sonnet-4-6"

# — Backend / wiring —

# Optional. Port the Bun backend serves on (server.ts). Default 4820.
# Note: 4820/4821 are currently squatted by the other Orca workspace sessions
# on this machine — this session runs on 4822.
# PORT=4822

# Optional. Where agent workers file cases (worker, testset runner, Flue
# workflow). Default http://localhost:4820 — point it at your running backend.
# API_URL="http://localhost:4822"
